{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "_comment": "Inject current workflow progress into session context.",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd' inject-status"
          }
        ]
      }
    ],
    "Notification": [
      {
        "_comment": "Desktop notification when Claude finishes work or needs input. Cross-platform.",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd' notify-complete"
          }
        ]
      }
    ]
  }
}
