{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/flight505/flight505-harness/schema/state-v1.schema.json",
  "title": "Harness State Contract v1",
  "description": "Shared state envelope written by every harness plugin to .claude/harness/",
  "type": "object",
  "required": [
    "schema",
    "workflow_id",
    "phase_id",
    "plugin",
    "run_id",
    "status",
    "started_at",
    "updated_at"
  ],
  "properties": {
    "schema": {
      "const": "harness/v1",
      "description": "Schema version identifier"
    },
    "workflow_id": {
      "type": "string",
      "description": "ID of the parent workflow (from workflow.yaml name field)"
    },
    "phase_id": {
      "type": "string",
      "description": "ID of this phase within the workflow"
    },
    "plugin": {
      "type": "string",
      "enum": [
        "conductor",
        "harness-build",
        "harness-optimize",
        "harness-research",
        "harness-triage"
      ],
      "description": "Which harness plugin owns this state"
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this run (e.g., build-001, opt-003)"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "skipped",
        "cancelled"
      ],
      "description": "Current phase status"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this phase started"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last state update"
    },
    "elapsed_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "Wall-clock seconds since phase started"
    },
    "progress": {
      "type": "object",
      "description": "Optional progress tracking",
      "required": ["current", "total", "unit"],
      "properties": {
        "current": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "description": "What is being counted (experiments, stories, papers, etc.)"
        }
      },
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "description": "Tracked metric for optimization phases",
      "required": ["name", "direction", "baseline", "current"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Metric name (e.g., val_bpb, p99_latency_ms)"
        },
        "direction": {
          "type": "string",
          "enum": ["lower", "higher"],
          "description": "Whether lower or higher values are better"
        },
        "baseline": {
          "type": "number",
          "description": "Initial metric value before optimization"
        },
        "current": {
          "type": "number",
          "description": "Most recent metric value"
        },
        "best": {
          "type": "number",
          "description": "Best metric value achieved so far"
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["experiment", "value", "status"],
            "properties": {
              "experiment": {
                "type": "integer",
                "minimum": 1
              },
              "value": {
                "type": "number"
              },
              "status": {
                "type": "string",
                "enum": ["baseline", "kept", "reverted"]
              },
              "description": {
                "type": "string",
                "description": "Brief description of what was changed"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "description": "Plugin-specific output data. Shape varies by plugin.",
      "additionalProperties": true
    },
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["message"],
          "properties": {
            "message": {
              "type": "string",
              "description": "Human-readable error message"
            },
            "code": {
              "type": "string",
              "description": "Machine-readable error code"
            },
            "phase_id": {
              "type": "string",
              "description": "Which phase failed (for conductor-level errors)"
            }
          },
          "additionalProperties": false
        }
      ],
      "description": "Error details if status is 'failed', null otherwise"
    },
    "config": {
      "type": "object",
      "description": "Snapshot of the config used for this phase (from workflow.yaml)",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
