# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Temporary files
*.tmp
.cache/

# Claude Code local settings (ignore everything except hooks)
.claude/*
!.claude/hooks/

# Node (dashboard)
node_modules/
.next/
.env*.local

# Harness runtime state (generated, not committed)
# .harness/*.json is runtime state — don't commit
# workflow.yaml IS committed (it's the input definition)
.harness/
# But keep example state files
!examples/.harness/
